#include <iostream>
#include <string>
#include <cstring>
using namespace std;

// Define the Student struct
struct Student {
    int age;
    string first_name;
    string last_name;
    int standard;
};

int main() {
    Student s;
    
    // Read input
    cin >> s.age;
    cin >> s.first_name;
    cin >> s.last_name;
    cin >> s.standard;
    
    // Output
    cout << s.age << " " << s.first_name << " " << s.last_name << " " << s.standard << endl;
    
    return 0;
}
