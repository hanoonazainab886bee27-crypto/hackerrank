#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int n;
    cin >> n;
    
    vector<int> v(n);
    for (int i = 0; i < n; i++) {
        cin >> v[i];
    }
    
    int q;
    cin >> q;
    
    for (int i = 0; i < q; i++) {
        int x;
        cin >> x;
        
        // lower_bound returns iterator to first element >= x
        auto it = lower_bound(v.begin(), v.end(), x);
        
        // Calculate 1-based index
        int index = it - v.begin() + 1;
        
        if (*it == x) {
            cout << "Yes " << index << endl;
        } else {
            cout << "No " << index << endl;
        }
    }
    
    return 0;
}
