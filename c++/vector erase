#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;
    
    vector<int> v(n);
    for (int i = 0; i < n; i++) {
        cin >> v[i];
    }
    
    // First query: position to erase (1-based)
    int pos;
    cin >> pos;
    v.erase(v.begin() + (pos - 1));
    
    // Second query: range to erase (1-based, inclusive a, exclusive b)
    int a, b;
    cin >> a >> b;
    v.erase(v.begin() + (a - 1), v.begin() + (b - 1));
    
    // Output
    cout << v.size() << endl;
    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }
    
    return 0;
}
