#include <stdio.h>
#include <stdlib.h>

void update(int *a, int *b) {
    // Store the initial values to ensure calculations are correct
    int val_a = *a;
    int val_b = *b;
    
    // Update the value at address 'a' to be the sum
    *a = val_a + val_b;
    
    // Update the value at address 'b' to be the absolute difference
    // abs() returns the absolute value of an integer
    *b = abs(val_a - val_b);
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    // Read input - Note: &a and &b provide the memory addresses
    if (scanf("%d %d", &a, &b) == 2) {
        update(pa, pb);
        printf("%d\n%d", a, b);
    }

    return 0;
}
